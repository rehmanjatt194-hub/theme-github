{%- style -%}
  .blog-slider-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  .blog-slider__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .blog-slider__title {
    font-family: var(--font-heading-family);
    font-size: clamp(3rem, 5vw, 4.4rem);
    margin: 0;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .blog-slider__subheading {
    font-size: 1.6rem;
    color: rgba(var(--color-foreground), 0.7);
    margin-top: 1.2rem;
  }

  .blog-slider__container {
    position: relative;
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 4rem;
  }

  .blog-slider__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    gap: 2.5rem;
    padding-bottom: 2rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .blog-slider__track::-webkit-scrollbar {
    display: none;
  }

  .blog-slider__card {
    flex: 0 0 calc(33.333% - 1.7rem);
    min-width: 320px;
    scroll-snap-align: start;
    border-radius: 28px;
    overflow: hidden;
    position: relative;
    aspect-ratio: 1 / 1.15;
    background: #f0f0f0;
  }

  @media screen and (max-width: 1100px) {
    .blog-slider__card {
      flex: 0 0 calc(50% - 1.25rem);
    }
    .blog-slider__container {
      padding: 0 2rem;
    }
  }

  @media screen and (max-width: 750px) {
    .blog-slider__card {
      flex: 0 0 85%;
      min-width: 280px;
    }
  }

  .blog-slider__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .blog-slider__card:hover .blog-slider__image {
    transform: scale(1.08);
  }

  .blog-slider__overlay {
    position: absolute;
    top: 2.5rem;
    left: 2.5rem;
    right: 2.5rem;
    background: rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-radius: 20px;
    padding: 1.8rem 2.2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #fff;
    z-index: 2;
    transition: background 0.3s ease;
  }
  
  .blog-slider__card:hover .blog-slider__overlay {
     background: rgba(0, 0, 0, 0.25);
  }

  .blog-slider__card-info {
    flex: 1;
    overflow: hidden;
  }

  .blog-slider__card-title {
    font-size: 1.9rem;
    font-weight: 500;
    margin: 0;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .blog-slider__card-subtext {
    font-size: 1.2rem;
    opacity: 0.85;
    margin-top: 0.3rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 400;
  }

  .blog-slider__arrow-box {
    width: 44px;
    height: 44px;
    background: #fff;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000;
    margin-left: 1.5rem;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }
  
  .blog-slider__card:hover .blog-slider__arrow-box {
    transform: scale(1.1);
  }

  .blog-slider__arrow-box svg {
    width: 22px;
    height: 22px;
    transform: rotate(-45deg);
  }

  .blog-slider__nav {
    display: flex;
    justify-content: center;
    gap: 1.2rem;
    margin-top: 4rem;
  }

  .blog-slider__nav-btn {
    width: 52px;
    height: 42px;
    border: 1px solid rgba(var(--color-foreground), 0.15);
    border-radius: 10px;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    color: #000;
  }

  .blog-slider__nav-btn:hover {
    border-color: #000;
    background: #f9f9f9;
  }

  .blog-slider__nav-btn svg {
    width: 18px;
    height: 18px;
  }

  .blog-slider__footer {
    text-align: center;
    margin-top: 6rem;
  }

  .blog-slider__button {
    display: inline-block;
    padding: 1.8rem 7rem;
    border: 1.5px solid rgb(var(--color-foreground));
    border-radius: 100px;
    text-decoration: none;
    color: rgb(var(--color-foreground));
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .blog-slider__button:hover {
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    transform: translateY(-2px);
  }
{%- endstyle -%}

<section class="blog-slider blog-slider-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="blog-slider__header page-width" data-animate>
    {% if section.settings.title != blank %}
      <h2 class="blog-slider__title">{{ section.settings.title | escape }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="blog-slider__subheading">{{ section.settings.subheading | escape }}</p>
    {% endif %}
  </div>

  <div class="blog-slider__container">
    <div class="blog-slider__track" id="BlogSlider-{{ section.id }}" data-animate>
      {%- assign blog = blogs[section.settings.blog] -%}
      {%- if blog != blank and blog.articles_count > 0 -%}
        {%- for article in blog.articles limit: section.settings.post_limit -%}
          <div class="blog-slider__card stagger-item">
            <a href="{{ article.url }}" class="blog-slider__card-link">
              {%- if article.image -%}
                {{ article.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'blog-slider__image' }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg blog-slider__image' }}
              {%- endif -%}
              
              <div class="blog-slider__overlay">
                <div class="blog-slider__card-info">
                  <h3 class="blog-slider__card-title">{{ article.title | escape }}</h3>
                  <div class="blog-slider__card-subtext">
                    {%- if article.tags.size > 0 -%}
                      {{ article.tags[0] }}
                    {%- else -%}
                      {{ 'now' | date: "%B %d, %Y" }}
                    {%- endif -%}
                  </div>
                </div>
                <div class="blog-slider__arrow-box">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </div>
              </div>
            </a>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..6) -%}
          <div class="blog-slider__card stagger-item">
             {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
             {{ 'collection-' | append: current | placeholder_svg_tag: 'placeholder-svg blog-slider__image' }}
             <div class="blog-slider__overlay">
                <div class="blog-slider__card-info">
                  <h3 class="blog-slider__card-title">Sample Article {{ i }}</h3>
                  <div class="blog-slider__card-subtext">Wellness & Lifestyle</div>
                </div>
                <div class="blog-slider__arrow-box">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </div>
              </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="blog-slider__nav" data-animate="fade">
      <button class="blog-slider__nav-btn" aria-label="Previous slide" onclick="document.getElementById('BlogSlider-{{ section.id }}').scrollBy({left: -350, behavior: 'smooth'})">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
      </button>
      <button class="blog-slider__nav-btn" aria-label="Next slide" onclick="document.getElementById('BlogSlider-{{ section.id }}').scrollBy({left: 350, behavior: 'smooth'})">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </button>
    </div>
  </div>

  {% if section.settings.button_label != blank %}
    <div class="blog-slider__footer page-width" data-animate>
      <a href="{{ section.settings.button_link | default: blog.url | default: '#' }}" class="blog-slider__button">
        {{ section.settings.button_label | escape }}
      </a>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Blog Slider Jewelry",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Active ingredients"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Based in nature and supported by science"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "post_limit",
      "min": 3,
      "max": 12,
      "step": 1,
      "label": "Posts to show",
      "default": 6
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Custom Background Color",
      "default": "#fdfaf7"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Blog Slider Jewelry"
    }
  ]
}
{% endschema %}
