{%- style -%}
  .faq-jewelry--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: transparent;
  }

  .faq-jewelry__title {
    margin-bottom: 4rem;
    font-family: var(--font-heading-family);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 400;
  }

  .faq-jewelry__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0 4rem;
  }

  @media screen and (min-width: 750px) {
    .faq-jewelry__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .faq-jewelry__item {
    border-bottom: 1px solid rgba(var(--color-foreground), 0.1);
    padding: 2rem 0;
  }

  .faq-jewelry__item summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    list-style: none;
    cursor: pointer;
    font-size: 1.6rem;
    font-weight: 400;
    line-height: 1.4;
    color: rgb(var(--color-foreground));
  }

  .faq-jewelry__item summary::-webkit-details-marker {
    display: none;
  }

  .faq-jewelry__icon {
    font-size: 2rem;
    font-weight: 200;
    margin-left: 2rem;
    transition: transform 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
  }

  .faq-jewelry__item[open] .faq-jewelry__icon {
    transform: rotate(45deg);
  }

  .faq-jewelry__content {
    padding-top: 1.5rem;
    line-height: 1.8;
    color: rgba(var(--color-foreground), 0.75);
    font-size: 1.4rem;
  }
  
  .faq-jewelry__content p {
    margin: 0;
  }
{%- endstyle -%}

<div class="faq-jewelry faq-jewelry--{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="faq-jewelry__title center">{{ section.settings.title | escape }}</h2>
    {%- endif -%}

    <div class="faq-jewelry__grid" data-animate>
      {%- for block in section.blocks -%}
        <details class="faq-jewelry__item stagger-item" {{ block.shopify_attributes }}>
          <summary>
            <span>{{ block.settings.question | escape }}</span>
            <span class="faq-jewelry__icon">+</span>
          </summary>
          <div class="faq-jewelry__content rte">
            {{ block.settings.answer }}
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "FAQ Jewelry",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "FAQ"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How Do I Charge The Lamps?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Use the provided USB cable to charge the lamps for 4-6 hours for a full charge.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Jewelry",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "How Do I Charge The Lamps?" } },
        { "type": "faq_item", "settings": { "question": "How Do I Charge Multiple Lamps At Once?" } },
        { "type": "faq_item", "settings": { "question": "Light Intensity Of The Lamp Is Very Low, Is It Broken?" } },
        { "type": "faq_item", "settings": { "question": "How Long For A Fully Charged Battery?" } },
        { "type": "faq_item", "settings": { "question": "How Long Does The Shipping Take?" } },
        { "type": "faq_item", "settings": { "question": "How to Reset Your Password?" } }
      ]
    }
  ]
}
{% endschema %}
