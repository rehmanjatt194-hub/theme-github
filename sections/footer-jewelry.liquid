{%- style -%}
  .footer-jewelry {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    font-family: var(--font-body-family);
    line-height: 1.5;
  }

  .footer-jewelry__top {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr) 1.5fr;
    gap: 4rem;
    padding-bottom: 6rem;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.1);
  }

  @media screen and (max-width: 1100px) {
    .footer-jewelry__top {
      grid-template-columns: 1fr 1fr;
      gap: 5rem 2rem;
    }
  }

  @media screen and (max-width: 750px) {
    .footer-jewelry__top {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }

  .footer-jewelry__logo img {
    height: auto;
    max-width: 160px;
    display: block;
  }

  .footer-jewelry__heading {
    font-family: var(--font-heading-family);
    font-size: 1.8rem;
    font-weight: 600;
    margin-top: 0;
    margin-bottom: 2.5rem;
    color: inherit;
    letter-spacing: 0.02em;
  }

  .footer-jewelry__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-jewelry__list-item {
    margin-bottom: 1.2rem;
  }

  .footer-jewelry__link {
    color: inherit;
    text-decoration: none;
    font-size: 1.5rem;
    opacity: 0.75;
    transition: all 0.3s ease;
  }

  .footer-jewelry__link:hover {
    opacity: 1;
    padding-left: 5px;
  }

  .footer-jewelry__social {
    display: flex;
    flex-direction: column;
  }

  .footer-jewelry__social-icons {
    display: flex;
    gap: 1.6rem;
    margin-top: 0.5rem;
  }

  .footer-jewelry__social-link {
    color: inherit;
    width: 20px;
    height: 20px;
    opacity: 0.85;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .footer-jewelry__social-link:hover {
    transform: scale(1.2);
    opacity: 1;
  }

  .footer-jewelry__social-link svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .footer-jewelry__bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-top: 5rem;
  }

  @media screen and (max-width: 990px) {
    .footer-jewelry__bottom {
      flex-direction: column;
      align-items: center;
      gap: 4rem;
      text-align: center;
    }
  }

  .footer-jewelry__legal {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .footer-jewelry__policy-links {
    display: flex;
    gap: 2.5rem;
  }

  @media screen and (max-width: 750px) {
     .footer-jewelry__policy-links {
        justify-content: center;
        flex-wrap: wrap;
        gap: 1.5rem;
     }
  }

  .footer-jewelry__copyright {
    font-size: 1.3rem;
    opacity: 0.5;
    margin-top: 0.5rem;
  }

  .footer-jewelry__newsletter {
    max-width: 500px;
    width: 100%;
  }

  .footer-jewelry__newsletter-form {
    display: flex;
    gap: 0;
    width: 100%;
    position: relative;
  }

  .footer-jewelry__input {
    flex: 1;
    background: #fff;
    border: 1px solid rgba(var(--color-foreground), 0.15);
    border-radius: 100px;
    padding: 1.6rem 3rem;
    padding-right: 14rem;
    color: #000;
    font-size: 1.5rem;
    outline: none;
    transition: border-color 0.3s ease;
  }

  .footer-jewelry__input:focus {
    border-color: rgb(var(--color-foreground));
  }

  .footer-jewelry__submit {
    position: absolute;
    right: 0.6rem;
    top: 0.6rem;
    bottom: 0.6rem;
    background: #000;
    color: #fff;
    border: none;
    border-radius: 100px;
    padding: 0 4rem;
    font-weight: 600;
    font-size: 1.4rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.3s ease;
  }

  .footer-jewelry__submit:hover {
    background: #333;
  }
  
  .footer-jewelry__message {
    margin-top: 1rem;
    font-size: 1.3rem;
  }
{%- endstyle -%}

<footer class="footer-jewelry color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    
    <div class="footer-jewelry__top" data-animate>
      
      {%- comment -%} LOGO COLUMN {%- endcomment -%}
      <div class="footer-jewelry__logo-col stagger-item">
        <div class="footer-jewelry__logo">
          {%- if section.settings.logo != blank -%}
            {{ section.settings.logo | image_url: width: 400 | image_tag: loading: 'lazy' }}
          {%- elsif settings.logo != blank -%}
             {{ settings.logo | image_url: width: 400 | image_tag: loading: 'lazy' }}
          {%- else -%}
            <span class="h2" style="font-family: var(--font-heading-family);">{{ shop.name }}</span>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} MENU COLUMNS {%- endcomment -%}
      {%- assign menu_count = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          {%- assign menu_count = menu_count | plus: 1 -%}
          <div class="footer-jewelry__menu-col stagger-item" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h3 class="footer-jewelry__heading">{{ block.settings.heading | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              <ul class="footer-jewelry__list">
                {%- for link in block.settings.menu.links -%}
                  <li class="footer-jewelry__list-item">
                    <a href="{{ link.url }}" class="footer-jewelry__link">{{ link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
      
      {%- comment -%} Placeholder menus if none added {%- endcomment -%}
      {%- if menu_count == 0 -%}
        {%- for i in (1..3) -%}
          <div class="footer-jewelry__menu-col stagger-item">
            <h3 class="footer-jewelry__heading">Menu {{ i }}</h3>
            <ul class="footer-jewelry__list">
               <li class="footer-jewelry__list-item"><a href="#" class="footer-jewelry__link">Sample Link</a></li>
               <li class="footer-jewelry__list-item"><a href="#" class="footer-jewelry__link">Privacy Policy</a></li>
            </ul>
          </div>
        {%- endfor -%}
      {%- endif -%}

      {%- comment -%} SOCIAL COLUMN {%- endcomment -%}
      <div class="footer-jewelry__social stagger-item">
         <h3 class="footer-jewelry__heading">{{ section.settings.social_heading | escape }}</h3>
         <div class="footer-jewelry__social-icons">
            {%- if settings.social_instagram_link != blank -%}
              <a href="{{ settings.social_instagram_link }}" class="footer-jewelry__social-link" aria-label="Instagram">{% render 'icon', icon: 'instagram' %}</a>
            {%- endif -%}
            {%- if settings.social_facebook_link != blank -%}
              <a href="{{ settings.social_facebook_link }}" class="footer-jewelry__social-link" aria-label="Facebook">{% render 'icon', icon: 'facebook' %}</a>
            {%- endif -%}
            {%- if settings.social_youtube_link != blank -%}
              <a href="{{ settings.social_youtube_link }}" class="footer-jewelry__social-link" aria-label="YouTube">{% render 'icon', icon: 'youtube' %}</a>
            {%- endif -%}
            {%- if settings.social_pinterest_link != blank -%}
              <a href="{{ settings.social_pinterest_link }}" class="footer-jewelry__social-link" aria-label="Pinterest">{% render 'icon', icon: 'pinterest' %}</a>
            {%- endif -%}
            {%- if settings.social_twitter_link != blank or settings.social_x_link != blank -%}
               <a href="{{ settings.social_twitter_link | default: settings.social_x_link }}" class="footer-jewelry__social-link" aria-label="X">{% render 'icon', icon: 'x' %}</a>
            {%- endif -%}
         </div>
      </div>

    </div>

    <div class="footer-jewelry__bottom" data-animate="fade">
      
      <div class="footer-jewelry__legal">
        <div class="footer-jewelry__policy-links">
           {%- if section.settings.bottom_menu != blank -%}
             {%- for link in section.settings.bottom_menu.links -%}
               <a href="{{ link.url }}" class="footer-jewelry__link" style="font-size: 1.3rem;">{{ link.title }}</a>
             {%- endfor -%}
           {%- else -%}
             <a href="/policies/privacy-policy" class="footer-jewelry__link" style="font-size: 1.3rem;">Privacy Policy</a>
             <a href="/policies/terms-of-service" class="footer-jewelry__link" style="font-size: 1.3rem;">Terms of Service</a>
           {%- endif -%}
        </div>
        <div class="footer-jewelry__copyright">
          &copy; {{ 'now' | date: "%Y" }}, {{ shop.name | link_to: routes.root_url }}
        </div>
      </div>

      <div class="footer-jewelry__newsletter">
        {%- form 'customer', class: 'footer-jewelry__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input
            id="NewsletterForm--{{ section.id }}"
            type="email"
            name="contact[email]"
            class="footer-jewelry__input"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            placeholder="Email"
            required
          >
          <button type="submit" class="footer-jewelry__submit" name="commit" id="Subscribe">
            Join
          </button>
          
          {%- if form.errors -%}
            <div class="footer-jewelry__message color-error" id="Newsletter-error--{{ section.id }}">
              {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
            </div>
          {%- endif -%}

          {%- if form.posted_successfully? -%}
            <div class="footer-jewelry__message color-success" id="Newsletter-success--{{ section.id }}" tabindex="-1" autofocus>
              Success! Thank you for joining.
            </div>
          {%- endif -%}
        {%- endform -%}
      </div>

    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer Jewelry",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer Logo"
    },
    {
      "type": "text",
      "id": "social_heading",
      "label": "Social Heading",
      "default": "Let's be social"
    },
    {
      "type": "link_list",
      "id": "bottom_menu",
      "label": "Bottom Menu (Privacy, Terms)"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Custom Background Color",
      "default": "#fdfaf7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Custom Text Color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu Column",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Featured Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer Jewelry",
      "blocks": [
        { "type": "link_list", "settings": { "heading": "Popular sections" } },
        { "type": "link_list", "settings": { "heading": "Featured Links" } },
        { "type": "link_list", "settings": { "heading": "Featured Links" } }
      ]
    }
  ]
}
{% endschema %}
