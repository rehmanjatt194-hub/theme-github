{%- style -%}
  .circular-categories-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: #fff;
  }
  .circular-categories__title {
    text-align: center;
    margin-bottom: 40px;
    font-family: var(--font-heading--family);
    font-size: 28px;
    font-weight: 400;
    color: #000;
  }
  .circular-categories__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .circular-categories__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    width: 150px;
    transition: transform 0.3s ease;
  }
  .circular-categories__item:hover {
    transform: translateY(-5px);
  }
  .circular-categories__image-wrapper {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    overflow: hidden;
    background-color: #f9f9f9;
    margin-bottom: 15px;
    display: flex;
    justify-content: center;
    align-items: center;
    border: 1px solid #eee;
  }
  .circular-categories__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .circular-categories__label {
    font-family: var(--font-body--family);
    font-size: 14px;
    color: #666;
    text-align: center;
    font-weight: 500;
  }
  
  @media screen and (max-width: 749px) {
    .circular-categories__image-wrapper {
      width: 100px;
      height: 100px;
    }
    .circular-categories__item {
      width: 100px;
    }
    .circular-categories__grid {
      gap: 15px;
    }
  }
{%- endstyle -%}

<div class="circular-categories-{{ section.id }}">
  {% if section.settings.title != blank %}
    <h2 class="circular-categories__title">{{ section.settings.title | escape }}</h2>
  {% endif %}

  <div class="circular-categories__grid" data-animate>
    {% for block in section.blocks %}
      {%- assign collection = collections[block.settings.collection] -%}
      <a href="{{ collection.url | default: '#' }}" class="circular-categories__item stagger-item" {{ block.shopify_attributes }}>
        <div class="circular-categories__image-wrapper">
          {% if block.settings.image != blank or collection.image != blank or collection.featured_image != blank %}
            {% liquid
              assign image = block.settings.image | default: collection.image | default: collection.featured_image
            %}
            {{ image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'circular-categories__image' }}
          {% else %}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
        <span class="circular-categories__label">
          {{ block.settings.title | default: collection.title | default: "Category" }}
        </span>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Circular Categories",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Popular Categories"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image (Optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Circular Categories",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
