{%- style -%}
  .features-bar-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: #fff;
    border-top: 1px solid #f0f0f0;
    border-bottom: 1px solid #f0f0f0;
  }
  .features-bar__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    gap: 20px;
  }
  .features-bar__item {
    display: flex;
    align-items: center;
    flex: 1;
    min-width: 200px;
    gap: 15px;
  }
  .features-bar__icon {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #333;
  }
  .features-bar__icon svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }
  .features-bar__content {
    display: flex;
    flex-direction: column;
  }
  .features-bar__title {
    font-family: var(--font-body--family);
    font-size: 14px;
    font-weight: 700;
    color: #000;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .features-bar__text {
    font-family: var(--font-body--family);
    font-size: 12px;
    color: #888;
    line-height: 1.4;
    margin-top: 2px;
  }

  @media screen and (max-width: 749px) {
    .features-bar__grid {
      justify-content: center;
      gap: 30px;
    }
    .features-bar__item {
      min-width: 100%;
      justify-content: center;
      text-align: center;
      flex-direction: column;
      gap: 10px;
    }
  }
{%- endstyle -%}

<div class="features-bar-{{ section.id }}">
  <div class="features-bar__grid" data-animate>
    {% for block in section.blocks %}
      <div class="features-bar__item stagger-item" {{ block.shopify_attributes }}>
        <div class="features-bar__icon">
          {% if block.settings.custom_icon_svg != blank %}
            {{ block.settings.custom_icon_svg }}
          {% else %}
            {% render 'icon', icon: block.settings.icon %}
          {% endif %}
        </div>
        <div class="features-bar__content">
          {% if block.settings.title != blank %}
            <span class="features-bar__title">{{ block.settings.title }}</span>
          {% endif %}
          {% if block.settings.text != blank %}
            <span class="features-bar__text">{{ block.settings.text }}</span>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Features Bar",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Shipping" },
            { "value": "return", "label": "Returns" },
            { "value": "lock", "label": "Secure Payment" },
            { "value": "chat_bubble", "label": "Support" },
            { "value": "price_tag", "label": "Best Price" },
            { "value": "star", "label": "Quality" }
          ],
          "default": "truck"
        },
        {
          "type": "html",
          "id": "custom_icon_svg",
          "label": "Custom Icon SVG (Optional)",
          "info": "Overrides the icon selection above."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Feature description goes here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features Bar",
      "blocks": [
        { "type": "feature", "settings": { "icon": "truck", "title": "Free Shipping", "text": "On order over $100" } },
        { "type": "feature", "settings": { "icon": "return", "title": "30 Day Returns", "text": "Easy returns in 7 days" } },
        { "type": "feature", "settings": { "icon": "lock", "title": "Money Guarantee", "text": "Cash On Delivery" } },
        { "type": "feature", "settings": { "icon": "chat_bubble", "title": "Online Support", "text": "Get us 24/7 at 123-456" } }
      ]
    }
  ]
}
{% endschema %}
